{
  "name": "skillpack-cli",
  "version": "1.0.0",
  "description": "CLI para inicializar e atualizar a pasta .agents (AGENTS.md + SKILL.md) do projeto, com suporte a múltiplos frameworks.",
  "type": "module",
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "skills": "./dist/cli.js"
  },
  "files": ["dist", "templates"],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check ./src ./tests",
    "lint:fix": "biome check --write ./src ./tests",
    "format": "biome format --write ./src ./tests",
    "check": "biome check ./src ./tests && tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run test && npm run build",
    "release": "changeset publish",
    "changeset:add": "changeset",
    "changeset:commit": "git add .changeset/* && git commit -m \"chore: adicionar changeset para novas alteracoes\""
  },
  "keywords": ["agents", "skills", "ai", "cli", "scaffold"],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "picocolors": "^1.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@changesets/cli": "^2.27.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.14.9",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
