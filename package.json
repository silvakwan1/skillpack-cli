{
  "name": "skillpack-cli",
  "version": "2.0.1",
  "private": false,
  "description": "CLI interativo para inicializar, gerenciar e atualizar a estrutura de agentes de IA (.agents/AGENTS.md e SKILL.md) no seu projeto. Padronize instruções para Claude, Cursor, Copilot, ChatGPT com suporte a múltiplos frameworks como Next.js e Laravel.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "skills": "dist/cli.js"
  },
  "bin-name": "skills",
  "files": [
    "dist",
    "templates"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check ./src ./tests",
    "lint:fix": "biome check --write ./src ./tests",
    "format": "biome format --write ./src ./tests",
    "check": "biome check ./src ./tests && tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run test && npm run build",
    "release": "changeset publish",
    "changeset:add": "changeset",
    "changeset:commit": "git add .changeset/* && git commit -m \"chore: adicionar changeset para novas alteracoes\""
  },
  "keywords": [
    "agents",
    "skills",
    "ai",
    "cli",
    "scaffold",
    "copilot",
    "cursorrules",
    "cursor",
    "claude",
    "chatgpt",
    "developer-experience",
    "prompt-engineering",
    "nextjs",
    "laravel",
    "boilerplate",
    "tooling",
    "ai-agents",
    "agentic-workflows",
    "assistant"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/silvakwan1/skillpack-cli.git"
  },
  "bugs": {
    "url": "https://github.com/silvakwan1/skillpack-cli/issues"
  },
  "homepage": "https://github.com/silvakwan1/skillpack-cli#readme",
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "picocolors": "^1.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@changesets/cli": "^2.27.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.14.9",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
